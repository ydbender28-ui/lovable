// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String              @id @default(cuid())
  name         String?
  email        String              @unique
  password     String
  createdAt    DateTime            @default(now())
  projects     Project[]
  agents       Agent[]
  memberships  WorkspaceMember[]
  ownedWorkspaces Workspace[]
  labsFlags    String              @default("[]") // JSON: string[] of enabled lab feature keys
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  ownerId   String
  owner     User              @relation(fields: [ownerId], references: [id])
  members   WorkspaceMember[]
  projects  Project[]
  createdAt DateTime          @default(now())
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  role        String    @default("editor") // owner | admin | editor
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
}

model Agent {
  id           String   @id @default(cuid())
  name         String
  description  String?
  systemPrompt String
  model        String   @default("claude-sonnet-4-6")
  avatar       String   @default("🤖")
  slug         String   @unique
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id])
  public       Boolean  @default(true)
  tools        String   @default("[]") // JSON: AgentTool[]
  knowledge    String   @default("[]") // JSON: { id, title, content }[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id            String    @id @default(cuid())
  name          String
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])
  workspaceId   String?
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  messages      Message[]
  versions      Version[]
  publishSlug     String?   @unique
  publishedHtml   String?
  publishedAt     DateTime?
  envVars         String?   // JSON: { KEY: VALUE }
  customDomain    String?   @unique
  publishPassword String?
  visitCount      Int       @default(0)
  knowledge       String    @default("[]") // JSON: { id, title, content }[]
  supabaseProjectId String?
  supabaseUrl       String?
  supabaseAnonKey   String?
}

model Version {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  files        String   // JSON: { [path]: content }
  modelUsed    String?
  inputTokens  Int?
  outputTokens Int?
  bookmarked   Boolean  @default(false)
  bookmarkNote String?
  createdAt    DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  projectId String
  eventType String   // pageview | click | ragclick | form_submit
  path      String?
  element   String?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

model ShareLink {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  projectId String
  filesJson String   // JSON: { [path]: content }
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  role      String
  content   String
  createdAt DateTime @default(now())
}
